# Blockfrost API key for Cardano Preview Testnet
# Get one at: https://blockfrost.io
BLOCKFROST_API_KEY=preview_your_key_here

# 24-word BIP-39 seed phrase for your Cardano wallet
# Fund it with test ADA from: https://docs.cardano.org/cardano-testnet/tools/faucet/
WALLET_SEED_PHRASE=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# Cardano network (Preview | Preprod | Mainnet)
NETWORK=Preview

# Deployed Aiken contract address (from contracts/deployment.json after aiken deploy)
ROUND_CONTRACT_ADDRESS=addr_test1...

# Thread policy ID minted when the round contract was initialized
THREAD_POLICY_ID=abc123...

# Commitment inbox contract address
COMMITMENT_CONTRACT_ADDRESS=addr_test1...

# Registry contract address
REGISTRY_CONTRACT_ADDRESS=addr_test1...

# Optional: Path to pre-generated ZK keys directory (default: ../zk-prover/keys)
ZK_KEYS_DIR=../zk-prover/keys

# Optional: Override path to Rust prover binary (default: ../zk-prover/target/release/zkfl-prover)
PROVER_BIN=../zk-prover/target/release/zkfl-prover
